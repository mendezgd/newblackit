---
export interface Props {
  tag:      string;
  title:    string;
  subtitle: string;
  // Each card is a detailed feature block
  cards: {
    icon:   string;  // 'chart' | 'brain' | 'cloud' | 'server' | 'code' | 'gear' | 'shield' | 'layers'
    title:  string;
    desc:   string;
    points?: string[];  // optional bullet points
  }[];
  // Optional stats shown in the hero band
  stats?: { value: string; label: string }[];
}

const {
  tag,
  title,
  subtitle,
  cards,
  stats = [],
} = Astro.props;

const icons: Record<string, string> = {
  chart: `<svg viewBox="0 0 48 48" fill="none"><rect x="4" y="28" width="7" height="16" rx="2" fill="currentColor" opacity=".3"/><rect x="14" y="20" width="7" height="24" rx="2" fill="currentColor" opacity=".55"/><rect x="24" y="12" width="7" height="32" rx="2" fill="currentColor" opacity=".8"/><rect x="34" y="4" width="7" height="40" rx="2" fill="currentColor"/><polyline points="7,28 17,20 27,12 37,4" stroke="currentColor" stroke-width="1.5" fill="none" opacity=".4"/><circle cx="37" cy="4" r="3" fill="currentColor"/></svg>`,
  brain: `<svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="10" stroke="currentColor" stroke-width="1.5"/><circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width=".8" stroke-dasharray="4 3" opacity=".3"/><circle cx="24" cy="5" r="3" fill="currentColor"/><circle cx="43" cy="24" r="3" fill="currentColor" opacity=".7"/><circle cx="5" cy="24" r="3" fill="currentColor" opacity=".5"/><circle cx="24" cy="43" r="3" fill="currentColor" opacity=".3"/><line x1="24" y1="8" x2="24" y2="14" stroke="currentColor" stroke-width="1" opacity=".4"/><line x1="40" y1="24" x2="34" y2="24" stroke="currentColor" stroke-width="1" opacity=".4"/><line x1="8" y1="24" x2="14" y2="24" stroke="currentColor" stroke-width="1" opacity=".4"/><line x1="24" y1="40" x2="24" y2="34" stroke="currentColor" stroke-width="1" opacity=".4"/></svg>`,
  cloud: `<svg viewBox="0 0 48 48" fill="none"><path d="M8 34c0-12 9-18 16-18s16 6 16 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line x1="4" y1="34" x2="44" y2="34" stroke="currentColor" stroke-width="1.5" opacity=".25" stroke-linecap="round"/><circle cx="24" cy="16" r="4" fill="currentColor" opacity=".7"/><path d="M14 34c0-7 4-12 10-12s10 5 10 12" stroke="currentColor" stroke-width="1" opacity=".4" stroke-linecap="round"/></svg>`,
  server: `<svg viewBox="0 0 48 48" fill="none"><rect x="6" y="8" width="36" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/><rect x="6" y="22" width="36" height="10" rx="2" stroke="currentColor" stroke-width="1.5" opacity=".75"/><rect x="6" y="36" width="36" height="8" rx="2" stroke="currentColor" stroke-width="1.5" opacity=".5"/><circle cx="37" cy="13" r="2" fill="currentColor"/><circle cx="37" cy="27" r="2" fill="currentColor" opacity=".6"/><circle cx="37" cy="40" r="2" fill="currentColor" opacity=".35"/><rect x="10" y="11" width="16" height="4" rx="1" fill="currentColor" opacity=".2"/></svg>`,
  code: `<svg viewBox="0 0 48 48" fill="none"><polyline points="16,12 6,24 16,36" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/><polyline points="32,12 42,24 32,36" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity=".7"/><line x1="28" y1="10" x2="20" y2="38" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity=".5"/></svg>`,
  gear: `<svg viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="7" stroke="currentColor" stroke-width="2"/><path d="M24 4v5M24 39v5M4 24h5M39 24h5M8.7 8.7l3.5 3.5M35.8 35.8l3.5 3.5M8.7 39.3l3.5-3.5M35.8 12.2l3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity=".6"/></svg>`,
  layers: `<svg viewBox="0 0 48 48" fill="none"><polygon points="24,4 44,14 24,24 4,14" stroke="currentColor" stroke-width="1.5" fill="rgba(245,166,35,.1)"/><polyline points="4,24 24,34 44,24" stroke="currentColor" stroke-width="1.5" fill="none" opacity=".65"/><polyline points="4,34 24,44 44,34" stroke="currentColor" stroke-width="1.5" fill="none" opacity=".35"/></svg>`,
  shield: `<svg viewBox="0 0 48 48" fill="none"><path d="M24 4l16 6v14c0 10-8 18-16 22C16 42 8 34 8 24V10z" stroke="currentColor" stroke-width="1.5" fill="rgba(245,166,35,.07)"/><polyline points="16,24 21,29 32,18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>`,
};
---

<div class="sp">

  <!-- ── HERO ── -->
  <div class="sp__hero">
    <div class="sp__hero-bg" aria-hidden="true"></div>
    <div class="sp__hero-inner">

      <div class="sp__hero-left">
        <nav class="sp__bread">
          <a href="/">Inicio</a>
          <span>/</span>
          <span>{tag}</span>
        </nav>
        <p class="section-label">{tag}</p>
        <h1 class="sp__title">{title}</h1>
        <p class="sp__sub">{subtitle}</p>
        <a class="btn btn--solid sp__hero-cta" href="/#contacto">
          Hablar con un especialista
        </a>
      </div>

      <!-- Right: decorative icon grid -->
      <div class="sp__hero-art" aria-hidden="true">
        <div class="sp__icon-grid">
          {cards.map((c, i) => (
            <div class={`sp__icon-tile sp__icon-tile--${i % 2 === 0 ? 'a' : 'b'}`}>
              <div class="sp__icon-tile-inner" set:html={icons[c.icon] ?? icons['gear']}></div>
              <span>{c.title}</span>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Stats band (if provided) -->
    {stats.length > 0 && (
      <div class="sp__stats">
        {stats.map(s => (
          <div class="sp__stat">
            <strong>{s.value}</strong>
            <small>{s.label}</small>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- ── FEATURES ── -->
  <div class="sp__features">
    {cards.map((c, i) => (
      <div class={`sp__feature sp__feature--${i % 2 === 0 ? 'normal' : 'alt'}`}>
        <div class="sp__feature-inner">

          <!-- Left: number + icon -->
          <div class="sp__feature-aside">
            <div class="sp__feature-num">0{i + 1}</div>
            <div class="sp__feature-icon" set:html={icons[c.icon] ?? icons['gear']}></div>
          </div>

          <!-- Right: content -->
          <div class="sp__feature-content">
            <h2 class="sp__feature-title">{c.title}</h2>
            <p class="sp__feature-desc">{c.desc}</p>
            {c.points && c.points.length > 0 && (
              <ul class="sp__feature-points">
                {c.points.map(pt => (
                  <li>
                    <span class="sp__point-dot" aria-hidden="true"></span>
                    {pt}
                  </li>
                ))}
              </ul>
            )}
          </div>

        </div>
      </div>
    ))}
  </div>

  <!-- ── CTA BAND ── -->
  <div class="sp__cta-band">
    <div class="sp__cta-inner">
      <div class="sp__cta-text">
        <h3>¿Listo para dar el siguiente paso?</h3>
        <p>Cuéntenos su proyecto y le respondemos en menos de 24 horas.</p>
      </div>
      <div class="sp__cta-actions">
        <a class="btn btn--solid"   href="/#contacto">Iniciar conversación</a>
        <a class="btn btn--outline" href="/">Ver todos los servicios</a>
      </div>
    </div>
  </div>

</div>

<style>
/* ─────────────────────────────────────────
   HERO
───────────────────────────────────────── */
.sp__hero {
  position: relative;
  overflow: hidden;
  border-bottom: 1px solid var(--border);
}

.sp__hero-bg {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(245,166,35,.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(245,166,35,.025) 1px, transparent 1px);
  background-size: 72px 72px;
  -webkit-mask-image: radial-gradient(ellipse 90% 90% at 10% 50%, black 20%, transparent 75%);
  mask-image: radial-gradient(ellipse 90% 90% at 10% 50%, black 20%, transparent 75%);
  pointer-events: none;
}

.sp__hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  padding: 6rem 2.5rem 5rem;
  max-width: 1200px;
  margin: 0 auto;
}

/* Left column */
.sp__hero-left { position: relative; }

.sp__bread {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--mono); font-size: 11px;
  color: var(--muted); letter-spacing: 0.06em; margin-bottom: 1.5rem;
}
.sp__bread a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
.sp__bread a:hover { color: var(--amber); }
.sp__bread span:last-child { color: var(--amber); }

.sp__title {
  font-family: var(--display);
  font-size: clamp(2.8rem, 5vw, 4.2rem);
  font-weight: 400;
  letter-spacing: 0.02em;
  line-height: 1.05;
  color: var(--text);
  margin: 0.5rem 0 1.25rem;
}

.sp__sub {
  font-size: 16px; color: var(--muted);
  line-height: 1.75; font-weight: 300;
  margin-bottom: 2.5rem;
  max-width: 480px;
}

.sp__hero-cta { align-self: flex-start; }

/* Right column: icon grid */
.sp__hero-art {
  display: flex;
  align-items: center;
  justify-content: center;
}

.sp__icon-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
  width: 100%;
  max-width: 420px;
}

.sp__icon-tile {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 2.5rem 1.5rem;
  background: var(--bg);
  transition: background 0.25s;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.sp__icon-tile::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--amber); transform: scaleX(0);
  transform-origin: left; transition: transform 0.3s;
}
.sp__icon-tile:hover { background: var(--bg2); }
.sp__icon-tile:hover::before { transform: scaleX(1); }

.sp__icon-tile--a { background: var(--bg); }
.sp__icon-tile--b { background: var(--bg2); }

.sp__icon-tile-inner {
  width: 44px; height: 44px;
  color: var(--amber);
  flex-shrink: 0;
}
.sp__icon-tile-inner svg { width: 100%; height: 100%; }

.sp__icon-tile span {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1.3;
}

/* Stats band */
.sp__stats {
  display: flex;
  border-top: 1px solid var(--border);
}
.sp__stat {
  flex: 1;
  padding: 1.75rem 2.5rem;
  border-right: 1px solid var(--border);
}
.sp__stat:last-child { border-right: none; }
.sp__stat strong {
  display: block;
  font-family: var(--display);
  font-size: 2.2rem; font-weight: 400;
  color: var(--amber); line-height: 1; margin-bottom: 4px;
}
.sp__stat small {
  font-family: var(--mono); font-size: 10px;
  color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase;
}

/* ─────────────────────────────────────────
   FEATURES — alternating rows
───────────────────────────────────────── */
.sp__features { border-bottom: 1px solid var(--border); }

.sp__feature {
  border-bottom: 1px solid var(--border);
}
.sp__feature:last-child { border-bottom: none; }
.sp__feature--alt { background: var(--bg2); }

.sp__feature-inner {
  display: grid;
  grid-template-columns: 180px 1fr;
  gap: 0;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2.5rem;
}

/* Left aside: big number + icon */
.sp__feature-aside {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  padding: 3.5rem 2rem 3.5rem 0;
  border-right: 1px solid var(--border);
  gap: 1rem;
}

.sp__feature-num {
  font-family: var(--display);
  font-size: 4.5rem;
  font-weight: 400;
  line-height: 1;
  color: rgba(245,166,35,.12);
  letter-spacing: 0.02em;
  user-select: none;
}

.sp__feature-icon {
  width: 48px; height: 48px;
  color: var(--amber);
  padding: 10px;
  background: rgba(245,166,35,.06);
  border: 1px solid rgba(245,166,35,.18);
  border-radius: 8px;
}
.sp__feature-icon svg { width: 100%; height: 100%; }

/* Right content */
.sp__feature-content {
  padding: 3.5rem 0 3.5rem 3rem;
}

.sp__feature-title {
  font-family: var(--display);
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  font-weight: 400;
  letter-spacing: 0.02em;
  color: var(--text);
  line-height: 1.05;
  margin-bottom: 1rem;
}

.sp__feature-desc {
  font-size: 15px;
  color: var(--muted);
  line-height: 1.8;
  font-weight: 300;
  max-width: 620px;
  margin-bottom: 1.5rem;
}

.sp__feature-points {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.sp__feature-points li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 14px;
  color: var(--muted);
  font-weight: 300;
  line-height: 1.6;
}
.sp__point-dot {
  display: block;
  width: 5px; height: 5px;
  background: var(--amber);
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 6px;
  opacity: 0.7;
}

/* ─────────────────────────────────────────
   CTA BAND
───────────────────────────────────────── */
.sp__cta-band {
  background: var(--bg2);
  border-top: 1px solid var(--border);
}
.sp__cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
  padding: 3.5rem 2.5rem;
  max-width: 1200px;
  margin: 0 auto;
}
.sp__cta-text h3 {
  font-family: var(--display);
  font-size: 1.8rem; font-weight: 400;
  letter-spacing: 0.02em; color: var(--text);
  margin-bottom: 0.4rem;
}
.sp__cta-text p {
  font-size: 14px; color: var(--muted); font-weight: 300;
}
.sp__cta-actions {
  display: flex; gap: 1rem; flex-wrap: wrap;
}

/* ─────────────────────────────────────────
   RESPONSIVE
───────────────────────────────────────── */
@media (max-width: 900px) {
  .sp__hero-inner {
    grid-template-columns: 1fr;
    gap: 3rem;
    padding: 5rem 1.5rem 4rem;
  }
  .sp__hero-art { justify-content: flex-start; }
  .sp__icon-grid { max-width: 100%; }

  .sp__feature-inner {
    grid-template-columns: 1fr;
    padding: 0 1.5rem;
  }
  .sp__feature-aside {
    flex-direction: row;
    align-items: center;
    padding: 2.5rem 0 0;
    border-right: none;
    border-bottom: 1px solid var(--border);
    gap: 1rem;
    padding-bottom: 1.5rem;
  }
  .sp__feature-num { font-size: 3rem; }
  .sp__feature-content { padding: 2rem 0 3rem; }

  .sp__stats { flex-wrap: wrap; }
  .sp__stat  { border-right: none; border-bottom: 1px solid var(--border); }
  .sp__stat:last-child { border-bottom: none; }

  .sp__cta-inner { flex-direction: column; align-items: flex-start; padding: 3rem 1.5rem; }
}

@media (max-width: 480px) {
  .sp__icon-grid { grid-template-columns: 1fr; }
  .sp__cta-actions { flex-direction: column; width: 100%; }
  .sp__cta-actions .btn { text-align: center; }
}
</style>
