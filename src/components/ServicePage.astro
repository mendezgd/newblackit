---
export interface Props {
  tag: string;
  title: string;
  subtitle: string;
  cards: {
    icon: string; // one of: 'chart' | 'brain' | 'server' | 'code' | 'cloud' | 'gear' | 'shield' | 'layers'
    title: string;
    desc: string;
  }[];
}

const { tag, title, subtitle, cards } = Astro.props;

const icons: Record<string, string> = {
  chart: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="4" y="28" width="7" height="16" rx="2" fill="currentColor" opacity=".3"/>
    <rect x="14" y="20" width="7" height="24" rx="2" fill="currentColor" opacity=".55"/>
    <rect x="24" y="12" width="7" height="32" rx="2" fill="currentColor" opacity=".75"/>
    <rect x="34" y="4"  width="7" height="40" rx="2" fill="currentColor"/>
    <polyline points="7,28 17,20 27,12 37,4" stroke="currentColor" stroke-width="1.5" fill="none" opacity=".4"/>
    <circle cx="27" cy="12" r="3" fill="currentColor" opacity=".7"/>
    <circle cx="37" cy="4"  r="3" fill="currentColor"/>
  </svg>`,

  brain: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="24" cy="24" r="10" stroke="currentColor" stroke-width="1.5"/>
    <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width=".8" stroke-dasharray="4 3" opacity=".3"/>
    <circle cx="24" cy="5"  r="3" fill="currentColor"/>
    <circle cx="43" cy="24" r="3" fill="currentColor" opacity=".7"/>
    <circle cx="5"  cy="24" r="3" fill="currentColor" opacity=".5"/>
    <circle cx="24" cy="43" r="3" fill="currentColor" opacity=".3"/>
    <line x1="24" y1="8"  x2="24" y2="14" stroke="currentColor" stroke-width="1" opacity=".4"/>
    <line x1="40" y1="24" x2="34" y2="24" stroke="currentColor" stroke-width="1" opacity=".4"/>
    <line x1="8"  y1="24" x2="14" y2="24" stroke="currentColor" stroke-width="1" opacity=".4"/>
    <line x1="24" y1="40" x2="24" y2="34" stroke="currentColor" stroke-width="1" opacity=".4"/>
  </svg>`,

  cloud: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M8 34c0-12 9-18 16-18s16 6 16 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    <line x1="4" y1="34" x2="44" y2="34" stroke="currentColor" stroke-width="1.5" opacity=".25" stroke-linecap="round"/>
    <circle cx="24" cy="16" r="4" fill="currentColor" opacity=".7"/>
    <path d="M14 34c0-7 4-12 10-12s10 5 10 12" stroke="currentColor" stroke-width="1" opacity=".4" stroke-linecap="round"/>
    <line x1="24" y1="36" x2="24" y2="44" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity=".5"/>
  </svg>`,

  server: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="6"  y="8"  width="36" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/>
    <rect x="6"  y="22" width="36" height="10" rx="2" stroke="currentColor" stroke-width="1.5" opacity=".75"/>
    <rect x="6"  y="36" width="36" height="8"  rx="2" stroke="currentColor" stroke-width="1.5" opacity=".5"/>
    <circle cx="37" cy="13" r="2" fill="currentColor"/>
    <circle cx="37" cy="27" r="2" fill="currentColor" opacity=".6"/>
    <circle cx="37" cy="40" r="2" fill="currentColor" opacity=".35"/>
    <rect x="10" y="11" width="16" height="4" rx="1" fill="currentColor" opacity=".2"/>
    <rect x="10" y="25" width="12" height="4" rx="1" fill="currentColor" opacity=".15"/>
  </svg>`,

  code: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <polyline points="16,12 6,24 16,36" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
    <polyline points="32,12 42,24 32,36" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity=".7"/>
    <line x1="28" y1="10" x2="20" y2="38" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity=".5"/>
  </svg>`,

  gear: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="24" cy="24" r="7" stroke="currentColor" stroke-width="2"/>
    <path d="M24 4v5M24 39v5M4 24h5M39 24h5M8.7 8.7l3.5 3.5M35.8 35.8l3.5 3.5M8.7 39.3l3.5-3.5M35.8 12.2l3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity=".6"/>
  </svg>`,

  layers: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <polygon points="24,4 44,14 24,24 4,14" stroke="currentColor" stroke-width="1.5" fill="rgba(245,166,35,.1)"/>
    <polyline points="4,24 24,34 44,24" stroke="currentColor" stroke-width="1.5" fill="none" opacity=".65"/>
    <polyline points="4,34 24,44 44,34" stroke="currentColor" stroke-width="1.5" fill="none" opacity=".35"/>
  </svg>`,

  shield: `<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M24 4l16 6v14c0 10-8 18-16 22C16 42 8 34 8 24V10z" stroke="currentColor" stroke-width="1.5" fill="rgba(245,166,35,.07)"/>
    <polyline points="16,24 21,29 32,18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  </svg>`,
};

// Index number for each card
const cardNumbers = ["01", "02", "03", "04", "05", "06"];
---

<div class="sp">
  <!-- ── Header compacto ── -->
  <div class="sp__header">
    <!-- Líneas decorativas de fondo -->
    <div class="sp__lines" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </div>
    <!-- Acento diagonal -->
    <div class="sp__accent" aria-hidden="true"></div>

    <div class="sp__header-inner">
      <nav class="sp__bread">
        <a href="/">Inicio</a>
        <span class="sp__bread-sep">/</span>
        <span>{tag}</span>
      </nav>

      <div class="sp__header-layout">
        <div class="sp__header-left">
          <p class="section-label">{tag}</p>
          <h1 class="sp__title">{title}</h1>
        </div>
        <div class="sp__header-right">
          <p class="sp__sub">{subtitle}</p>
          <a class="sp__cta-inline" href="/#contacto">
            Hablar con un especialista
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path
                d="M2 6h8M6 2l4 4-4 4"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Cards ── -->
  <div class="sp__cards" style={`--card-count: ${cards.length}`}>
    {
      cards.map((c, i) => (
        <div class="sp__card">
          <div class="sp__card-num">{cardNumbers[i]}</div>
          <div class="sp__card-top">
            <div
              class="sp__card-icon"
              set:html={icons[c.icon] ?? icons["gear"]}
            />
            <h3>{c.title}</h3>
          </div>
          <p>{c.desc}</p>
          <div class="sp__card-bar" aria-hidden="true" />
        </div>
      ))
    }
  </div>

  <!-- ── CTA bottom ── -->
  <div class="sp__footer-cta">
    <span class="sp__footer-label">¿Interesado en este servicio?</span>
    <a class="btn btn--solid" href="/#contacto">Hablar con un especialista</a>
  </div>
</div>

<style>
  /* ════════════════════════════════
   HEADER
════════════════════════════════ */
  .sp__header {
    position: relative;
    padding: 3.5rem 2.5rem 3rem;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    background: var(--bg);
  }

  /* Líneas verticales de fondo */
  .sp__lines {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }
  .sp__lines span {
    display: block;
    width: 1px;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(245, 166, 35, 0.07) 30%,
      rgba(245, 166, 35, 0.07) 70%,
      transparent 100%
    );
  }

  /* Acento diagonal amber */
  .sp__accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 320px;
    height: 3px;
    background: linear-gradient(90deg, var(--amber) 0%, transparent 100%);
  }

  .sp__header-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .sp__bread {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .sp__bread a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .sp__bread a:hover {
    color: var(--amber);
  }
  .sp__bread-sep {
    opacity: 0.3;
  }
  .sp__bread span:last-child {
    color: var(--amber);
  }

  /* Layout dos columnas */
  .sp__header-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: end;
  }

  .sp__title {
    font-family: var(--display);
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.05;
    color: var(--text);
    margin: 0.4rem 0 0;
  }

  .sp__sub {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.75;
    font-weight: 300;
    margin-bottom: 1.5rem;
  }

  .sp__cta-inline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--amber);
    text-decoration: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 16px;
    border: 1px solid rgba(245, 166, 35, 0.25);
    border-radius: 2px;
    transition:
      background 0.2s,
      border-color 0.2s;
  }
  .sp__cta-inline:hover {
    background: rgba(245, 166, 35, 0.06);
    border-color: rgba(245, 166, 35, 0.5);
  }
  .sp__cta-inline svg {
    flex-shrink: 0;
    transition: transform 0.2s;
  }
  .sp__cta-inline:hover svg {
    transform: translateX(3px);
  }

  /* ════════════════════════════════
   CARDS
════════════════════════════════ */
  .sp__cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1px;
    background: var(--border);
    border-bottom: 1px solid var(--border);
  }

  .sp__card {
    position: relative;
    background: var(--bg);
    padding: 2.25rem 2rem 2rem;
    transition: background 0.25s;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Número de esquina */
  .sp__card-num {
    font-family: var(--display);
    font-size: 3rem;
    line-height: 1;
    color: rgba(245, 166, 35, 0.07);
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    letter-spacing: 0.05em;
    pointer-events: none;
    transition: color 0.3s;
  }
  .sp__card:hover .sp__card-num {
    color: rgba(245, 166, 35, 0.14);
  }

  /* Icono + título inline */
  .sp__card-top {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .sp__card-icon {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--amber);
    background: rgba(245, 166, 35, 0.05);
    border: 1px solid rgba(245, 166, 35, 0.14);
    border-radius: 6px;
    padding: 8px;
    transition:
      background 0.25s,
      border-color 0.25s;
  }
  .sp__card-icon svg {
    width: 100%;
    height: 100%;
  }
  .sp__card:hover .sp__card-icon {
    background: rgba(245, 166, 35, 0.1);
    border-color: rgba(245, 166, 35, 0.3);
  }

  .sp__card-top h3 {
    font-family: var(--display);
    font-size: 1.35rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    color: var(--text);
    line-height: 1.1;
    transition: color 0.2s;
  }
  .sp__card:hover h3 {
    color: var(--amber);
  }

  .sp__card > p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.75;
    font-weight: 300;
    flex: 1;
  }

  /* Barra amber inferior animada */
  .sp__card-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--amber);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s ease;
  }
  .sp__card:hover .sp__card-bar {
    transform: scaleX(1);
  }
  .sp__card:hover {
    background: var(--bg2);
  }

  /* ════════════════════════════════
   FOOTER CTA
════════════════════════════════ */
  .sp__footer-cta {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    padding: 2.5rem 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .sp__footer-label {
    font-size: 14px;
    color: var(--muted);
    font-weight: 300;
  }

  /* ════════════════════════════════
   RESPONSIVE
════════════════════════════════ */
  @media (max-width: 768px) {
    .sp__header {
      padding: 2.5rem 1.5rem 2.5rem;
    }
    .sp__header-layout {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .sp__cards {
      grid-template-columns: 1fr;
    }
    .sp__footer-cta {
      padding: 2rem 1.5rem;
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
