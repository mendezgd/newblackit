---
import Base from '../layouts/Base.astro';

const techs = [
  'IBM Watson',
  'AWS',
  'IBM Cloud',
  'Check_MK',
  'Automation Anywhere',
  'Kubernetes',
  'Docker',
  'Terraform',
  'Grafana',
  'Elastic Stack',
  'Power BI',
  'Linux / Unix',
];
---
<Base title="Black It — Consultoría IT">

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="hero">
    <div class="hero__grid"  aria-hidden="true"></div>
    <div class="hero__glow"  aria-hidden="true"></div>
    <div class="hero__inner">

      <div class="hero__tag fu fu-1">
        <span class="hero__dot"></span>
        Consultoría IT · Buenos Aires, Argentina
      </div>

      <h1 class="hero__title fu fu-2">
        Tecnología<br />
        que resuelve<br />
        <em>problemas<br />reales.</em>
      </h1>

      <p class="hero__sub fu fu-3">
        Especialistas en monitoreo, inteligencia artificial, cloud computing
        y consultoría estratégica para empresas que necesitan que la
        tecnología funcione de verdad.
      </p>

      <div class="hero__actions fu fu-4">
        <a href="#servicios" class="btn btn--solid">Ver servicios</a>
        <a href="#contacto"  class="btn btn--outline">Hablar con un especialista</a>
      </div>

      <div class="hero__metrics fu fu-5">
        <div class="hero__metric">
          <strong>10<span>+</span></strong>
          <small>Años de experiencia</small>
        </div>
        <div class="hero__metric">
          <strong>50<span>+</span></strong>
          <small>Proyectos entregados</small>
        </div>
        <div class="hero__metric">
          <strong>4</strong>
          <small>Áreas de servicio</small>
        </div>
        <div class="hero__metric">
          <strong>24<span>/7</span></strong>
          <small>Soporte continuo</small>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ══════════════════════════════════════
       SERVICIOS
  ══════════════════════════════════════ -->
  <section class="section" id="servicios">
    <div class="container">
      <p class="section-label">Servicios</p>
      <h2 class="section-title">Lo que hacemos</h2>
      <p class="section-sub">
        Cuatro áreas de especialización profunda para cubrir el ciclo
        completo de la transformación tecnológica de su empresa.
      </p>

      <div class="srv-grid">

        <!-- Monitoreo -->
        <a href="/servicios/monitoreo" class="srv-card">
          <div class="srv-card__art">
            <svg viewBox="0 0 320 160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="0" y1="40"  x2="320" y2="40"  stroke="rgba(245,166,35,.08)" stroke-width="1"/>
              <line x1="0" y1="80"  x2="320" y2="80"  stroke="rgba(245,166,35,.08)" stroke-width="1"/>
              <line x1="0" y1="120" x2="320" y2="120" stroke="rgba(245,166,35,.08)" stroke-width="1"/>
              <line x1="64"  y1="0" x2="64"  y2="160" stroke="rgba(245,166,35,.08)" stroke-width="1"/>
              <line x1="128" y1="0" x2="128" y2="160" stroke="rgba(245,166,35,.08)" stroke-width="1"/>
              <line x1="192" y1="0" x2="192" y2="160" stroke="rgba(245,166,35,.08)" stroke-width="1"/>
              <line x1="256" y1="0" x2="256" y2="160" stroke="rgba(245,166,35,.08)" stroke-width="1"/>
              <polyline points="20,130 60,110 90,95 110,105 140,70 170,80 200,45 230,55 260,30 290,20" stroke="#f5a623" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              <polygon points="20,130 60,110 90,95 110,105 140,70 170,80 200,45 230,55 260,30 290,20 290,155 20,155" fill="url(#chartFill)" opacity="0.3"/>
              <circle cx="140" cy="70"  r="4" fill="#f5a623"/>
              <circle cx="200" cy="45"  r="4" fill="#f5a623"/>
              <circle cx="260" cy="30"  r="5" fill="#f5a623" opacity="0.9"/>
              <circle cx="260" cy="30" r="10" fill="#f5a623" opacity="0.12"/>
              <rect x="280" y="60"  width="6" height="80" rx="3" fill="rgba(245,166,35,.15)"/>
              <rect x="280" y="90"  width="6" height="50" rx="3" fill="#f5a623" opacity="0.6"/>
              <rect x="294" y="60"  width="6" height="80" rx="3" fill="rgba(245,166,35,.15)"/>
              <rect x="294" y="75"  width="6" height="65" rx="3" fill="#f5a623" opacity="0.45"/>
              <defs>
                <linearGradient id="chartFill" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#f5a623" stop-opacity="0.4"/>
                  <stop offset="100%" stop-color="#f5a623" stop-opacity="0"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div class="srv-card__body">
            <div class="srv-card__head">
              <span class="srv-card__num">01</span>
              <div class="srv-card__icon">
                <svg viewBox="0 0 22 22" fill="none">
                  <rect x="1"  y="13" width="3" height="8"  rx="1" fill="currentColor" opacity=".35"/>
                  <rect x="6"  y="8"  width="3" height="13" rx="1" fill="currentColor" opacity=".6"/>
                  <rect x="11" y="4"  width="3" height="17" rx="1" fill="currentColor" opacity=".8"/>
                  <rect x="16" y="1"  width="3" height="20" rx="1" fill="currentColor"/>
                  <polyline points="2.5,13 7.5,8 12.5,4 17.5,1" stroke="currentColor" stroke-width="1" fill="none" opacity=".4"/>
                </svg>
              </div>
            </div>
            <h3>Monitoreo</h3>
            <p>Visibilidad en tiempo real de aplicaciones, servicios e infraestructura. Check_MK con KPIs customizables y descubrimiento automático.</p>
            <div class="srv-card__tags">
              <span>Check_MK</span><span>KPIs</span><span>Alerting</span><span>Discovering</span>
            </div>
            <span class="srv-card__more">Ver más →</span>
          </div>
        </a>

        <!-- AI -->
        <a href="/servicios/ai" class="srv-card">
          <div class="srv-card__art">
            <svg viewBox="0 0 320 160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="40"  cy="40"  r="8" fill="rgba(245,166,35,.2)" stroke="#f5a623" stroke-width="1"/>
              <circle cx="40"  cy="80"  r="8" fill="rgba(245,166,35,.2)" stroke="#f5a623" stroke-width="1"/>
              <circle cx="40"  cy="120" r="8" fill="rgba(245,166,35,.2)" stroke="#f5a623" stroke-width="1"/>
              <circle cx="120" cy="30"  r="9" fill="rgba(245,166,35,.25)" stroke="#f5a623" stroke-width="1.2"/>
              <circle cx="120" cy="65"  r="9" fill="rgba(245,166,35,.35)" stroke="#f5a623" stroke-width="1.5"/>
              <circle cx="120" cy="100" r="9" fill="rgba(245,166,35,.25)" stroke="#f5a623" stroke-width="1.2"/>
              <circle cx="120" cy="135" r="9" fill="rgba(245,166,35,.15)" stroke="#f5a623" stroke-width="1"/>
              <circle cx="200" cy="45"  r="9" fill="rgba(245,166,35,.25)" stroke="#f5a623" stroke-width="1.2"/>
              <circle cx="200" cy="80"  r="10" fill="rgba(245,166,35,.5)" stroke="#f5a623" stroke-width="2"/>
              <circle cx="200" cy="115" r="9" fill="rgba(245,166,35,.2)" stroke="#f5a623" stroke-width="1.2"/>
              <circle cx="280" cy="60"  r="8" fill="rgba(245,166,35,.2)" stroke="#f5a623" stroke-width="1"/>
              <circle cx="280" cy="100" r="8" fill="rgba(245,166,35,.2)" stroke="#f5a623" stroke-width="1"/>
              <line x1="48" y1="40"  x2="111" y2="30"  stroke="#f5a623" stroke-width=".6" opacity=".25"/>
              <line x1="48" y1="40"  x2="111" y2="65"  stroke="#f5a623" stroke-width="1"  opacity=".5"/>
              <line x1="48" y1="80"  x2="111" y2="65"  stroke="#f5a623" stroke-width="1.2" opacity=".6"/>
              <line x1="48" y1="80"  x2="111" y2="100" stroke="#f5a623" stroke-width=".8"  opacity=".4"/>
              <line x1="48" y1="120" x2="111" y2="100" stroke="#f5a623" stroke-width=".6"  opacity=".3"/>
              <line x1="48" y1="120" x2="111" y2="135" stroke="#f5a623" stroke-width=".5"  opacity=".2"/>
              <line x1="129" y1="65"  x2="191" y2="45"  stroke="#f5a623" stroke-width=".8"  opacity=".4"/>
              <line x1="129" y1="65"  x2="191" y2="80"  stroke="#f5a623" stroke-width="1.5"  opacity=".7"/>
              <line x1="129" y1="100" x2="191" y2="80"  stroke="#f5a623" stroke-width="1.2"  opacity=".6"/>
              <line x1="129" y1="100" x2="191" y2="115" stroke="#f5a623" stroke-width=".7"  opacity=".35"/>
              <line x1="209" y1="80"  x2="272" y2="60"  stroke="#f5a623" stroke-width="1.2" opacity=".6"/>
              <line x1="209" y1="80"  x2="272" y2="100" stroke="#f5a623" stroke-width="1"   opacity=".5"/>
              <circle cx="200" cy="80" r="18" fill="#f5a623" opacity="0.05"/>
            </svg>
          </div>
          <div class="srv-card__body">
            <div class="srv-card__head">
              <span class="srv-card__num">02</span>
              <div class="srv-card__icon">
                <svg viewBox="0 0 22 22" fill="none">
                  <circle cx="11" cy="11" r="4"   stroke="currentColor" stroke-width="1.5"/>
                  <circle cx="11" cy="11" r="8.5" stroke="currentColor" stroke-width=".8" stroke-dasharray="3 2" opacity=".35"/>
                  <circle cx="11" cy="3"  r="1.5" fill="currentColor"/>
                  <circle cx="19" cy="11" r="1.5" fill="currentColor" opacity=".65"/>
                  <circle cx="3"  cy="11" r="1.5" fill="currentColor" opacity=".4"/>
                  <circle cx="11" cy="19" r="1.5" fill="currentColor" opacity=".25"/>
                </svg>
              </div>
            </div>
            <h3>Inteligencia Artificial</h3>
            <p>Profesionales homologados en IBM Watson. Business Intelligence, automatización RPA con Automation Anywhere e IA a escala empresarial.</p>
            <div class="srv-card__tags">
              <span>IBM Watson</span><span>BI & Analytics</span><span>RPA</span><span>AI a escala</span>
            </div>
            <span class="srv-card__more">Ver más →</span>
          </div>
        </a>

        <!-- Cloud -->
        <a href="/servicios/cloud" class="srv-card">
          <div class="srv-card__art">
            <svg viewBox="0 0 320 160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <ellipse cx="160" cy="75"  rx="90" ry="38" fill="rgba(245,166,35,.08)" stroke="#f5a623" stroke-width="1.2"/>
              <ellipse cx="120" cy="80"  rx="55" ry="28" fill="rgba(245,166,35,.06)" stroke="#f5a623" stroke-width=".8" opacity=".6"/>
              <ellipse cx="195" cy="82"  rx="48" ry="24" fill="rgba(245,166,35,.06)" stroke="#f5a623" stroke-width=".8" opacity=".5"/>
              <rect x="22" y="95"  width="48" height="8"  rx="2" fill="rgba(245,166,35,.15)" stroke="#f5a623" stroke-width=".8"/>
              <rect x="22" y="107" width="48" height="8"  rx="2" fill="rgba(245,166,35,.1)"  stroke="#f5a623" stroke-width=".8"/>
              <rect x="22" y="119" width="48" height="8"  rx="2" fill="rgba(245,166,35,.08)" stroke="#f5a623" stroke-width=".8"/>
              <circle cx="61" cy="99"  r="2" fill="#f5a623" opacity=".7"/>
              <circle cx="61" cy="111" r="2" fill="#f5a623" opacity=".4"/>
              <circle cx="61" cy="123" r="2" fill="rgba(245,166,35,.3)"/>
              <rect x="252" y="95"  width="46" height="8"  rx="2" fill="rgba(245,166,35,.15)" stroke="#f5a623" stroke-width=".8"/>
              <rect x="252" y="107" width="46" height="8"  rx="2" fill="rgba(245,166,35,.1)"  stroke="#f5a623" stroke-width=".8"/>
              <circle cx="289" cy="99"  r="2" fill="#f5a623" opacity=".7"/>
              <circle cx="289" cy="111" r="2" fill="#f5a623" opacity=".4"/>
              <line x1="160" y1="137" x2="160" y2="115" stroke="#f5a623" stroke-width="1.5" stroke-linecap="round"/>
              <polyline points="153,122 160,115 167,122" stroke="#f5a623" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
              <line x1="70"  y1="95" x2="100" y2="75" stroke="#f5a623" stroke-width=".8" stroke-dasharray="4 3" opacity=".5"/>
              <line x1="252" y1="95" x2="220" y2="75" stroke="#f5a623" stroke-width=".8" stroke-dasharray="4 3" opacity=".5"/>
              <text x="46"  y="88" font-family="monospace" font-size="8" fill="#f5a623" opacity=".5" text-anchor="middle">ON-PREM</text>
              <text x="275" y="88" font-family="monospace" font-size="8" fill="#f5a623" opacity=".5" text-anchor="middle">CLOUD</text>
            </svg>
          </div>
          <div class="srv-card__body">
            <div class="srv-card__head">
              <span class="srv-card__num">03</span>
              <div class="srv-card__icon">
                <svg viewBox="0 0 22 22" fill="none">
                  <path d="M4 17c0-6.5 5-10 8-10s8 3.5 8 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <line x1="2" y1="17" x2="22" y2="17" stroke="currentColor" stroke-width="1.2" opacity=".25" stroke-linecap="round"/>
                  <circle cx="12" cy="7" r="2.2" fill="currentColor" opacity=".75"/>
                  <path d="M8 17c0-4 2-7 4-7s4 3 4 7" stroke="currentColor" stroke-width=".8" opacity=".4" stroke-linecap="round"/>
                </svg>
              </div>
            </div>
            <h3>Cloud Solutions</h3>
            <p>Transición exitosa a AWS e IBM Cloud. Migramos, optimizamos y administramos su infraestructura cloud con el menor impacto operativo posible.</p>
            <div class="srv-card__tags">
              <span>AWS</span><span>IBM Cloud</span><span>Migración</span><span>FinOps</span>
            </div>
            <span class="srv-card__more">Ver más →</span>
          </div>
        </a>

        <!-- IT Consulting -->
        <a href="/servicios/it" class="srv-card">
          <div class="srv-card__art">
            <svg viewBox="0 0 320 160" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="160" cy="80" r="22" fill="rgba(245,166,35,.12)" stroke="#f5a623" stroke-width="1.5"/>
              <circle cx="160" cy="80" r="12" fill="rgba(245,166,35,.2)"  stroke="#f5a623" stroke-width="1"/>
              <rect x="28"  y="30"  width="44" height="28" rx="4" fill="rgba(245,166,35,.1)" stroke="#f5a623" stroke-width=".8"/>
              <rect x="248" y="30"  width="44" height="28" rx="4" fill="rgba(245,166,35,.1)" stroke="#f5a623" stroke-width=".8"/>
              <rect x="28"  y="102" width="44" height="28" rx="4" fill="rgba(245,166,35,.1)" stroke="#f5a623" stroke-width=".8"/>
              <rect x="248" y="102" width="44" height="28" rx="4" fill="rgba(245,166,35,.1)" stroke="#f5a623" stroke-width=".8"/>
              <text x="50"  y="48"  font-family="monospace" font-size="7" fill="#f5a623" opacity=".6" text-anchor="middle">ERP</text>
              <text x="270" y="48"  font-family="monospace" font-size="7" fill="#f5a623" opacity=".6" text-anchor="middle">CRM</text>
              <text x="50"  y="120" font-family="monospace" font-size="7" fill="#f5a623" opacity=".6" text-anchor="middle">CLOUD</text>
              <text x="270" y="120" font-family="monospace" font-size="7" fill="#f5a623" opacity=".6" text-anchor="middle">API</text>
              <line x1="72"  y1="52"  x2="140" y2="72"  stroke="#f5a623" stroke-width="1"   opacity=".45" stroke-dasharray="5 3"/>
              <line x1="248" y1="52"  x2="180" y2="72"  stroke="#f5a623" stroke-width="1"   opacity=".45" stroke-dasharray="5 3"/>
              <line x1="72"  y1="115" x2="140" y2="90"  stroke="#f5a623" stroke-width="1"   opacity=".45" stroke-dasharray="5 3"/>
              <line x1="248" y1="115" x2="180" y2="90"  stroke="#f5a623" stroke-width="1"   opacity=".45" stroke-dasharray="5 3"/>
              <circle cx="160" cy="80" r="32" stroke="#f5a623" stroke-width=".5" opacity=".15"/>
              <circle cx="160" cy="80" r="42" stroke="#f5a623" stroke-width=".4" opacity=".08"/>
            </svg>
          </div>
          <div class="srv-card__body">
            <div class="srv-card__head">
              <span class="srv-card__num">04</span>
              <div class="srv-card__icon">
                <svg viewBox="0 0 22 22" fill="none">
                  <rect x="2"  y="2"  width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/>
                  <rect x="13" y="2"  width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5" opacity=".55"/>
                  <rect x="2"  y="13" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5" opacity=".55"/>
                  <rect x="13" y="13" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5" opacity=".3"/>
                </svg>
              </div>
            </div>
            <h3>Consultoría de TI</h3>
            <p>Integración de sistemas, servicios administrados, gestión de proyectos y desarrollo a medida. Acompañamos cada etapa de su evolución tecnológica.</p>
            <div class="srv-card__tags">
              <span>Integración</span><span>MSP</span><span>PMO</span><span>Dev a medida</span>
            </div>
            <span class="srv-card__more">Ver más →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ══════════════════════════════════════
       TECNOLOGÍAS
  ══════════════════════════════════════ -->
  <section class="section section--alt" id="tecnologias">
    <div class="container">
      <p class="section-label">Tecnologías</p>
      <h2 class="section-title">Stack que dominamos</h2>
      <p class="section-sub">
        Plataformas líderes de la industria para garantizar soluciones
        robustas, escalables y con soporte a largo plazo.
      </p>

      <div class="tech-grid">
        {techs.map(t => (
          <div class="tech-item">
            <span class="tech-item__dot"></span>
            <span class="tech-item__name">{t}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ══════════════════════════════════════
       PROCESO
  ══════════════════════════════════════ -->
  <section class="section" id="proceso">
    <div class="container">
      <p class="section-label">Proceso</p>
      <h2 class="section-title">Cómo trabajamos</h2>
      <p class="section-sub">
        Un enfoque estructurado que minimiza riesgos y maximiza el
        impacto de cada proyecto.
      </p>

      <div class="process-grid">
        {[
          { n:'01', t:'Diagnóstico',    d:'Relevamiento profundo de su infraestructura, procesos y objetivos. Identificamos brechas y oportunidades con una visión objetiva.' },
          { n:'02', t:'Diseño',         d:'Arquitectura de la solución, selección de tecnologías y roadmap. Cada decisión justificada por criterios técnicos y de negocio.' },
          { n:'03', t:'Implementación', d:'Despliegue controlado por etapas con testing continuo y documentación exhaustiva. Mínimo impacto en sus operaciones actuales.' },
          { n:'04', t:'Soporte',        d:'Monitoreo continuo, capacitación del equipo y acompañamiento post-implementación. Su tecnología evoluciona con su negocio.' },
        ].map(s => (
          <div class="process-step">
            <span class="process-step__num">{s.n}</span>
            <h4 class="process-step__title">{s.t}</h4>
            <p class="process-step__desc">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- ══════════════════════════════════════
       CONTACTO — sin formulario
  ══════════════════════════════════════ -->
  <section class="section section--alt" id="contacto">
    <div class="container">
      <div class="contact-layout">

        <div class="contact-text">
          <p class="section-label">Contacto</p>
          <h2 class="section-title">¿Tiene un<br />proyecto<br />en mente?</h2>
          <p class="contact-desc">
            No importa en qué etapa se encuentre. Desde una consulta
            inicial hasta un proyecto en curso que necesita refuerzo.
            Hablemos.
          </p>
        </div>

        <div class="contact-channels">
          <a class="contact-channel" href="mailto:info@blackit.com.ar">
            <div class="contact-channel__icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M1.5 4.5l7.5 5.25 7.5-5.25M1.5 4.5h15v10.5h-15z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="contact-channel__body">
              <span class="contact-channel__label">Email</span>
              <span class="contact-channel__value">info@blackit.com.ar</span>
            </div>
            <svg class="contact-channel__arrow" width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M7 2l5 5-5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <div class="contact-channel contact-channel--location">
            <div class="contact-channel__icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="7.5" r="2.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M9 1.5C5.96 1.5 3.5 3.96 3.5 7c0 4 5.5 9.5 5.5 9.5S14.5 11 14.5 7c0-3.04-2.46-5.5-5.5-5.5z" stroke="currentColor" stroke-width="1.3"/>
              </svg>
            </div>
            <div class="contact-channel__body">
              <span class="contact-channel__label">Ubicación</span>
              <span class="contact-channel__value">Buenos Aires, Argentina</span>
            </div>
          </div>

          <div class="contact-note">
            <p>Respondemos todas las consultas dentro de las <strong>24 horas hábiles</strong>. Para urgencias, indicarlo en el asunto del email.</p>
          </div>
        </div>

